# Greet the user
print("Hello! I am AI Bot. What's your name? : ")

# Get user input
name = input()

# Respond to the user's name
print(f"Nice to meet you, {name}!")

# Ask a question
print("How are you feeling today? (good/bad) : ")
mood = input().lower()

# Use conditional statements to respond based on input
if mood == "good":
    print("I'm glad to hear that!")
elif mood == "bad":
    print("I'm sorry to hear that. Hope things get better soon.")
else:
    print(f"I see. Sometimes it's hard to put feelings into words.")

# Ask another question
print("Was today fun? (yes/no) :")
mood = input().lower()

# Use conditional statements to respond based on input
if mood == "yes":
    print("That's great! Hope you have fun tomorrow as well!")
elif mood == "no":
    print("That's really bad, Hope tomorrow will be better. ")
else:
    print(f"I see, you can't really express today, huh?")

# End the conversation
print(f"It was nice chatting with you {name}. Goodbye!")